# WhatsNaija AI Environment Variables
# Copy this file to .env and fill in your actual values

# =============================================================================
# WhatsApp Cloud API
# Get these from: https://developers.facebook.com/apps/
# =============================================================================
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_access_token_here
WHATSAPP_VERIFY_TOKEN=whatsnaijaai_secure_token_123  # Create your own random string
WABA_ID=your_waba_id_here

# =============================================================================
# Groq API
# Get your API key from: https://console.groq.com/
# =============================================================================
GROQ_API_KEY=gsk_your-groq-key-here

# =============================================================================
# Supabase
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# =============================================================================
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =============================================================================
# Application Settings
# =============================================================================
APP_ENV=development  # development | production
BASE_URL=http://localhost:8000  # Update this for production (e.g., Railway URL)

# =============================================================================
# Paystack (Optional - for payment integration)
# =============================================================================
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret
